if SHIELD_STAINLESS_LEFT

# Name must be less than 16 characters long!
config ZMK_KEYBOARD_NAME
    default "Stainless"

config ZMK_SPLIT_ROLE_CENTRAL
    default y

config ZMK_SPLIT_BLE_CENTRAL_PERIPHERALS
  default 2

config BT_MAX_CONN
  default 2

config BT_MAX_PAIRED
  default 2

endif

if SHIELD_STAINLESS_LEFT || SHIELD_STAINLESS_RIGHT

config ZMK_SPLIT
    default y

endif

if SHIELD_STAINLESS_DONGLE

# Name must be less than 16 characters long!
config ZMK_KEYBOARD_NAME
    default "Stainless"

config ZMK_SPLIT
    default y

config ZMK_SPLIT_ROLE_CENTRAL
    default y

config ZMK_SPLIT_BLE_CENTRAL_PERIPHERALS
  default 2

config BT_MAX_CONN
  default 2

config BT_MAX_PAIRED
  default 2

endif

# ---------------------
# Kconfig for shield "stainless_left" with board "nice_nano_v2"
# ---------------------
if BOARD_NICE_NANO_V2 && SHIELD_STAINLESS_LEFT

config SPI
    default y

endif
