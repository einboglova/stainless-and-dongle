#include <behaviors.dtsi>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/pointing.h>

/ {
    behaviors {
        encoder_left: encoder_left {
            compatible = "zmk,behavior-sensor-rotate";
            label = "ENCODER_LEFT";
            #sensor-binding-cells = <0>;
            bindings = <&msc SCRL_RIGHT>, <&msc SCRL_LEFT>;
        };

        sensor_right: sensor_right {
            compatible = "zmk,behavior-sensor-rotate";
            label = "SENSOR_RIGHT";
            #sensor-binding-cells = <0>;
            bindings = <&msc SCRL_UP>, <&msc SCRL_DOWN>;
        };
    };

    keymap {
        compatible = "zmk,keymap";

        default_layer {
            display-name = "Base";
            bindings = <
&kp ESC    &kp N1    &kp N2    &kp N3              &kp N4               &kp N5                            &kp N6  &kp N7       &kp N8           &kp N9    &kp N0     &kp BSLH
&kp TAB    &kp Q     &kp W     &kp E               &kp R                &kp T                             &kp Y   &kp U        &kp I            &kp O     &kp P      &kp BSPC
&kp LCTRL  &kp A     &kp S     &kp D               &kp F                &kp G                             &kp H   &kp J        &kp K            &kp L     &kp SQT    &kp RET
&kp LSHFT  &kp Z     &kp X     &kp C               &kp V                &kp B   &kp DEL    &kp SEMICOLON  &kp N   &kp M        &kp COMMA        &kp DOT   &kp FSLH   &kp UP
&kp LALT   &kp LGUI  &kp LALT  &lt 2 LEFT_BRACKET  &lt 3 RIGHT_BRACKET  &mo 1   &kp SPACE  &kp SPACE      &mo 2   &lt 1 EQUAL  &lt 3 SEMICOLON  &kp LEFT  &kp RIGHT  &kp DOWN
            >;

            sensor-bindings = <&inc_dec_kp C_VOL_UP C_VOL_DN &inc_dec_kp PG_UP PG_DN>;
        };

        layer_1 {
            bindings = <
&kp GRAVE   &kp F1  &kp F2  &kp F3  &kp F4  &kp F5                            &kp F6  &kp F7  &kp F8  &kp F9    &kp F10           &kp F11
&kp TILDE   &trans  &trans  &trans  &trans  &trans                            &trans  &trans  &trans  &trans    &kp LEFT_BRACKET  &kp RIGHT_BRACKET
&caps_word  &trans  &trans  &trans  &trans  &trans                            &trans  &trans  &trans  &trans    &trans            &kp F12
&trans      &trans  &trans  &trans  &trans  &trans  &kp K_PLAY_PAUSE  &trans  &trans  &trans  &trans  &trans    &trans            &kp K_VOLUME_UP
&trans      &trans  &trans  &trans  &trans  &trans  &trans            &trans  &trans  &trans  &trans  &kp HOME  &kp END           &kp K_VOLUME_DOWN
            >;
        };

        layer_2 {
            bindings = <
&trans  &kp ESC    &kp FSLH  &kp LS(KP_MULTIPLY)  &kp MINUS   &kp PLUS                  &trans  &trans  &trans  &trans  &trans  &trans
&trans  &kp LC(C)  &kp N7    &kp N8               &kp N9      &kp LPAR                  &trans  &trans  &trans  &trans  &trans  &trans
&trans  &kp LC(V)  &kp N4    &kp N5               &kp N6      &kp RPAR                  &trans  &trans  &trans  &trans  &trans  &trans
&trans  &kp LC(Z)  &kp N1    &kp N2               &kp N3      &kp RET   &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans
&trans  &kp LC(Y)  &kp N0    &trans               &kp KP_DOT  &kp RET   &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans
            >;
        };

        layer_3 {
            bindings = <
&bt BT_CLR  &bt BT_SEL 0  &bt BT_SEL 1  &bt BT_SEL 2  &bt BT_SEL 3  &bt BT_SEL 4                  &trans  &trans  &trans  &trans  &trans  &trans
&bt BT_PRV  &bt BT_NXT    &trans        &trans        &trans        &trans                        &trans  &trans  &trans  &trans  &trans  &trans
&trans      &trans        &trans        &trans        &trans        &trans                        &trans  &trans  &trans  &trans  &trans  &studio_unlock
&trans      &trans        &trans        &trans        &trans        &trans        &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans
&trans      &trans        &trans        &trans        &trans        &trans        &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans
            >;
        };
    };
};
